generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String       @id
  name              String
  email             String
  emailVerified     Boolean      @default(false)
  image             String?
  phoneNumber       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt
  sessions          Session[]
  accounts          Account[]
  posts             Post[]
  purchasedPosts    Post[]       @relation("boughtBy")
  favorites         Favorite[]
  reports           Report[]
  discussionsBuyer  Discussion[] @relation("discussionBuyer")
  discussionsSeller Discussion[] @relation("discussionSeller")
  messages          Message[]

  username        String?
  displayUsername String?
  bio             String?
  ratingsReceived Rating[]        @relation("ratee")
  ratingsGiven    Rating[]        @relation("rater")
  configurations  Configuration[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Post {
  id                 String              @id @default(cuid())
  userId             String
  title              String              @db.VarChar(50)
  description        String?
  price              Int
  componentId        String
  component          Component           @relation(fields: [componentId], references: [id])
  location           Location?
  Favorites          Favorite[]
  Report             Report[]
  Discussion         Discussion[]
  user               User                @relation(fields: [userId], references: [id])
  images             String[]
  ConfigurationItems ConfigurationItem[]
  isSold             Boolean             @default(false)
  boughtById         String?
  boughtBy           User?               @relation("boughtBy", fields: [boughtById], references: [id], onDelete: SetNull)

  @@map("post")
}

model Location {
  id          String  @id @default(cuid())
  lat         Float
  lon         Float
  name        String
  displayName String
  city        String
  state       String
  region      String
  country     String
  countryCode String
  coordinates Float[]

  postId String @unique
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("location")
}

model Favorite {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("favorite")
}

enum REPORT_TYPE {
  SPAM
  INNAPPROPRIATE
  HARASSMENT
  SCAM
  OTHER
}

enum REPORT_CONTENT {
  USER
  POST
  MESSAGE
}

model Report {
  id         String         @id @default(cuid())
  reason     REPORT_TYPE
  details    String?
  type       REPORT_CONTENT
  postId     String?
  post       Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId  String?
  reportedAt DateTime       @default(now())

  @@map("report")
}

model Discussion {
  id        String    @id @default(cuid())
  buyerId   String
  buyer     User      @relation("discussionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  postId    String
  post      Post?     @relation(fields: [postId], references: [id])
  messages  Message[]
  sellerId  String?
  seller    User?     @relation("discussionSeller", fields: [sellerId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([postId, buyerId])
  @@map("discussion")
}

enum MessageType {
  TEXT
  OFFER
  SYSTEM
}

model Message {
  id           String      @id @default(cuid())
  discussionId String
  discussion   Discussion  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  type         MessageType @default(TEXT)
  price        Int?        @db.SmallInt
  content      String?
  authorID     String?
  author       User?       @relation(fields: [authorID], references: [id], onDelete: Cascade)
  sendedAt     DateTime    @default(now())
  viewed       Boolean     @default(false)
  imageUrls    String[]
  buttonLabel  String?
  buttonUrl    String?
  buttonAction String?

  @@map("message")
}

model Rating {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation("ratee", fields: [userId], references: [id], onDelete: Cascade)
  raterId String
  rater   User   @relation("rater", fields: [raterId], references: [id], onDelete: Cascade)

  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now())

  @@map("rating")
}

model Configuration {
  id        String              @id @default(cuid())
  name      String              @db.VarChar(100)
  userId    String?
  user      User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPublic  Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  items     ConfigurationItem[]

  @@map("configuration")
}

model ConfigurationItem {
  id              String        @id @default(cuid())
  configurationId String
  configuration   Configuration @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  componentType   ComponentType
  postId          String?
  post            Post?         @relation(fields: [postId], references: [id], onDelete: SetNull)
  quantity        Int           @default(1) @db.SmallInt

  @@map("configuration_item")
}
