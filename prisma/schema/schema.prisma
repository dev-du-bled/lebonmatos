generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id
  name              String
  email             String
  emailVerified     Boolean      @default(false)
  image             String?
  phoneNumber       String?
  profileImageId    String?      @unique
  profileImage      Images?      @relation("UserProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt
  sessions          Session[]
  accounts          Account[]
  posts             Post[]
  favorites         Favorite[]
  reports           Report[]
  discussionsBuyer  Discussion[] @relation("discussionBuyer")
  discussionsSeller Discussion[] @relation("discussionSeller")
  messages          Message[]

  username        String?
  displayUsername String?
  ratingsReceived Rating[] @relation("ratee")
  ratingsGiven    Rating[] @relation("rater")
  images          Images[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Post {
  id          String       @id @default(cuid())
  userId      String
  title       String       @db.VarChar(50)
  description String?
  price       Int
  componentId String
  component   Component    @relation(fields: [componentId], references: [id])
  Favorites   Favorite[]
  Report      Report[]
  Discussion  Discussion[]
  user        User         @relation(fields: [userId], references: [id])
  images      Images[]

  @@map("post")
}

model Favorite {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("favorite")
}

model Images {
  id           String  @id @default(cuid())
  data         String
  alt          String?
  postId       String?
  ownerId      String
  owner        User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  isPrivate    Boolean @default(false)
  post         Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  profileImage User?   @relation("UserProfileImage")

  @@map("images")
}

enum REPORT_TYPE {
  SPAM
  INNAPPROPRIATE
  HARASSMENT
  SCAM
  OTHER
}

enum REPORT_CONTENT {
  USER
  POST
  MESSAGE
}

model Report {
  id         String         @id @default(cuid())
  reason     REPORT_TYPE
  details    String?
  type       REPORT_CONTENT
  postId     String?
  post       Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId  String?
  reportedAt DateTime       @default(now())

  @@map("report")
}

model Discussion {
  id       String    @id @default(cuid())
  buyerId  String
  buyer    User      @relation("discussionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  postId   String
  post     Post?     @relation(fields: [postId], references: [id])
  messages Message[]
  sellerId String?
  seller   User?     @relation("discussionSeller", fields: [sellerId], references: [id])

  @@map("discussion")
}

model Message {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  price        Int?       @db.SmallInt
  content      String?
  authorID     String
  author       User       @relation(fields: [authorID], references: [id], onDelete: Cascade)
  sendedAt     DateTime   @default(now())
  viewed       Boolean    @default(false)

  @@map("message")
}

model Rating {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation("ratee", fields: [userId], references: [id], onDelete: Cascade)
  raterId String
  rater   User   @relation("rater", fields: [raterId], references: [id], onDelete: Cascade)

  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now())

  @@map("rating")
}
